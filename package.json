{
  "name": "walletui",
  "version": "0.1.0",
  "description": "A terminal-native Solana wallet for developers and power users",
  "type": "module",
  "bin": {
    "walletui": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "solana",
    "wallet",
    "tui",
    "terminal",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@solana/kit": "^6.3.1",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "ink-link": "^5.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
