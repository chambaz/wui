{
  "name": "@chambaz/walletui",
  "version": "1.1.0",
  "description": "A terminal-native Solana wallet for developers and power users",
  "type": "module",
  "bin": {
    "wui": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "prepublishOnly": "pnpm build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "solana",
    "wallet",
    "tui",
    "terminal",
    "cli"
  ],
  "license": "MIT",
  "author": "Adam Chambers <adammchambers@gmail.com>",
  "dependencies": {
    "@ledgerhq/device-management-kit": "^1.2.0",
    "@ledgerhq/device-signer-kit-solana": "^1.7.1",
    "@ledgerhq/device-transport-kit-node-hid": "^1.0.0",
    "@solana-program/stake": "^0.6.0",
    "@solana-program/system": "^0.12.0",
    "@solana/kit": "^6.3.1",
    "dotenv": "^17.3.1",
    "ink": "^6.8.0",
    "ink-link": "^5.0.0",
    "react": "^19.2.4",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "bufferutil",
      "esbuild",
      "node-hid",
      "usb",
      "utf-8-validate"
    ]
  }
}
